# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=fabric_erp_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@fabricerp.com

# Security (Set to True in production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# Celery (Optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Company Settings
COMPANY_NAME=FabricERP
COMPANY_PHONE=+20123456789
COMPANY_EMAIL=info@fabricerp.com
COMPANY_ADDRESS=Egypt, Cairo

# Session Settings
SESSION_TIMEOUT=1800  # 30 minutes in seconds
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION=900  # 15 minutes in seconds

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fabric_erp.log

# API Settings
API_VERSION=v1
API_BASE_URL=/api/v1

# Environment
ENVIRONMENT=development

# Superuser (Optional - for initialization)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@fabricerp.com
ADMIN_PASSWORD=Admin123!@#